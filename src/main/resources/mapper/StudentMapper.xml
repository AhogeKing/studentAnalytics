<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ahogeking.studentanalytics.mapper.StudentMapper">

    <resultMap id="StudentResultMap" type="com.ahogeking.studentanalytics.entity.Student">
        <id column="id" property="id"/>
        <result column="student_no" property="studentNo"/>
        <result column="name" property="name"/>
        <result column="age" property="age"/>
        <result column="grade_level" property="gradeLevel"/>
        <result column="class_name" property="className"/>
        <result column="gender" property="gender"/>
        <result column="ethnicity" property="ethnicity"/>
        <result column="parental_education" property="parentalEducation"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <resultMap id="StudentPageRowResultMap" type="com.ahogeking.studentanalytics.dto.StudentPageRow">
        <result column="student_no" property="studentNo"/>
        <result column="name" property="name"/>
        <result column="age" property="age"/>
        <result column="gender" property="gender"/>
        <result column="grade_level" property="gradeLevel"/>
        <result column="class_name" property="className"/>
        <result column="gpa" property="gpa"/>
        <result column="grade_class" property="gradeClass"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="BaseColumnList">
        id,
        student_no,
        name,
        age,
        grade_level,
        class_name,
        gender,
        ethnicity,
        parental_education,
        created_at,
        updated_at,
        deleted
    </sql>

    <select id="selectStudentPageRows" resultMap="StudentPageRowResultMap">
        SELECT
        s.student_no,
        s.name,
        s.age,
        s.gender,
        s.grade_level,
        s.class_name,
        p.gpa,
        p.grade_class,
        GREATEST(s.updated_at, COALESCE(p.updated_at, s.updated_at)) AS update_time
        FROM student s
        LEFT JOIN student_performance p ON p.student_id = s.id
        WHERE s.deleted = 0
        ORDER BY s.student_no ASC
    </select>

</mapper>
